PORT=3001

# Comma-separated allowed frontend origins for CORS.
# Example: http://localhost:5173,https://your-project.vercel.app
CORS_ORIGIN=http://localhost:5173
# Supports wildcard patterns too, for Vercel previews:
# CORS_ORIGIN=http://localhost:5173,https://your-project.vercel.app,https://*.vercel.app

# Blockchain settings
RPC_URL=http://127.0.0.1:8545/
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
PRIVATE_KEY=

# Pinata credentials
# Preferred:
PINATA_JWT_TOKEN=

# Alternative (only if JWT is not used):
PINATA_API_KEY=
PINATA_API_SECRET=

# Watermark controls
# Default false: if watermarking fails, image watermark step is skipped.
WATERMARK_STRICT=false
