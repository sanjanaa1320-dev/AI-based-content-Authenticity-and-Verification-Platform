# RPC endpoint used for Sepolia deployments
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional explicit Sepolia endpoint override (defaults to RPC_URL)
SEPOLIA_RPC_URL=

# Optional RPC endpoint for Polygon Amoy deployments
ALCHEMY_AMOY_URL=

# Preferred signer for deploys (same key you can reuse in backend/.env)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional fallback signer. If both are set, PRIVATE_KEY is used.
WALLET_MNEMONIC=
